# Server
HOST=0.0.0.0
PORT=3001

# Database
DATABASE_URL=postgres://digitaria:secret@localhost:5432/digitaria

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRY_SECS=900
JWT_REFRESH_EXPIRY_SECS=604800

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Midtrans
MIDTRANS_SERVER_KEY=
